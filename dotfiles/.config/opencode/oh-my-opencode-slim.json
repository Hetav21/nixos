{
  "preset": "@preset@",
  "disabled_agents": [],
  "presets": {
    "@preset@": {
      "orchestrator": {
        "model": "@orchestratorModel@",
        "skills": [
          "*"
        ],
        "mcps": [
          "*"
        ]
      },
      "oracle": {
        "model": "@oracleModel@",
        "variant": "high",
        "skills": [
          "simplify",
          "deslop",
          "receiving-code-review",
          "requesting-code-review",
          "workflow",
          "systematic-debugging",
          "codebase-design",
          "domain-modeling",
          "improve-codebase-architecture"
        ],
        "mcps": [
          "context7",
          "awslabs.aws-documentation-mcp-server",
          "aws-knowledge-mcp-server",
          "azure-devops",
          "websearch"
        ]
      },
      "librarian": {
        "model": "@librarianModel@",
        "variant": "low",
        "skills": [
          "find-skills",
          "using-superpowers",
          "research"
        ],
        "mcps": [
          "context7",
          "awslabs.aws-documentation-mcp-server",
          "aws-knowledge-mcp-server",
          "atlassian",
          "azure-devops",
          "websearch",
          "grep_app"
        ]
      },
      "explorer": {
        "model": "@explorerModel@",
        "variant": "low",
        "skills": [
          "find-skills",
          "wayfinder",
          "triage"
        ],
        "mcps": [
          "atlassian",
          "grep_app"
        ]
      },
      "designer": {
        "model": "@designerModel@",
        "variant": "medium",
        "skills": [
          "agent-browser",
          "prototype"
        ],
        "mcps": [
          "playwright"
        ]
      },
      "fixer": {
        "model": "@fixerModel@",
        "variant": "low",
        "skills": [
          "using-git-worktrees",
          "agent-browser",
          "test-driven-development",
          "executing-plans",
          "verification-before-completion",
          "resolving-merge-conflicts",
          "finishing-a-development-branch",
          "systematic-debugging"
        ],
        "mcps": [
          "playwright",
          "azure-devops",
          "atlassian"
        ]
      },
      "observer": {
        "model": "@observerModel@",
        "variant": "medium",
        "skills": [
          "pdf",
          "docx",
          "pptx",
          "xlsx"
        ],
        "mcps": []
      }
    }
  },
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "council": {
    "master": {
      "model": "@orchestratorModel@",
      "variant": "high"
    },
    "master_timeout": 300000,
    "councillors_timeout": 180000,
    "master_fallback": [
      "@oracleModel@"
    ],
    "councillor_retries": 3,
    "default_preset": "default",
    "presets": {
      "default": {
        "alpha": {
          "model": "@orchestratorModel@",
          "variant": "high",
          "prompt": "Prioritize correctness, key trade-offs, and the highest-risk concerns."
        },
        "beta": {
          "model": "@oracleModel@",
          "variant": "high",
          "prompt": "Prioritize implementation details, failure modes, and concrete alternatives."
        },
        "gamma": {
          "model": "@librarianModel@",
          "variant": "medium",
          "prompt": "Be concise and independent. Challenge assumptions and surface simpler options."
        }
      },
      "fast": {
        "alpha": {
          "model": "@librarianModel@",
          "variant": "medium",
          "prompt": "Give a fast independent opinion focused on the main risk and best next step."
        },
        "beta": {
          "model": "@oracleModel@",
          "variant": "medium",
          "prompt": "Give a fast practical review focused on execution details and likely edge cases."
        }
      },
      "deep": {
        "master": {
          "model": "@orchestratorModel@",
          "variant": "high"
        },
        "alpha": {
          "model": "@orchestratorModel@",
          "variant": "high",
          "prompt": "Focus on architecture, long-term maintainability, and hidden trade-offs."
        },
        "beta": {
          "model": "@oracleModel@",
          "variant": "high",
          "prompt": "Focus on implementation realism, edge cases, and failure modes."
        },
        "gamma": {
          "model": "@librarianModel@",
          "variant": "medium",
          "prompt": "Focus on simplicity, unnecessary complexity, and the smallest viable approach."
        },
        "delta": {
          "model": "@orchestratorModel@",
          "variant": "medium",
          "prompt": "Focus on operational risk, reliability, and whether the recommendation is safe to trust."
        }
      }
    }
  }
}
