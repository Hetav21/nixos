{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@simonwjackson/opencode-direnv",
    "oh-my-opencode-slim"
  ],
  "model": "github-copilot/gpt-5-mini",
  "small_model": "github-copilot/gpt-5-mini",
  "agent": {
    "build": {
      "model": "github-copilot/gpt-5-mini"
    },
    "plan": {
      "model": "github-copilot/gpt-5-mini"
    },
    "general": {
      "disable": true,
      "model": "github-copilot/gpt-5-mini"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "explore": {
      "disable": true,
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    }
  }
}
