[color]
	ui = auto

[core]
	editor = vim

[pull]
	rebase = false

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[merge]
	conflictStyle = diff3

[credential]
	helper = libsecret

[alias]
	aa = add -A
	st = status -s
	sta = status
	ci = commit
	co = checkout
	cod = checkout .
	rh = reset HEAD
    cdf = clean -df
	br = branch
	bra = branch -a
	pr = pull --rebase
    amend = commit -a --amend --no-edit
    famend = commit --amend
	unstage = reset HEAD --
	last = log -1 HEAD
	lg = log --graph --oneline --decorate --all
